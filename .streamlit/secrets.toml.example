GROQ_API_KEY = "your_groq_api_key_here"
GROQ_MODEL   = "llama-3.3-70b-versatile"

# Gmail IMAP poller (channels/gmail_poller.py)
# Use a Gmail App Password — NOT your real Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS  = "complaintiq.demo@gmail.com"
GMAIL_APP_PASS = "xxxx xxxx xxxx xxxx"

# Supabase PostgreSQL Connection String (only used in Cloud deployment)
DATABASE_URL = "postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"
