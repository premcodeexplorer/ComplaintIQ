[32m+[m[32m-> Agent 1 (Intake): working...[m
[32m+[m[32mOK Agent 1 (Intake): done[m
[32m+[m[32m-> Agent 2 (Classifier): working...[m
[32m+[m[32mOK Agent 2 (Classifier): done[m
[32m+[m[32m-> Agent 3 (Duplicate Detector): working...[m
[32m+[m[32mOK Agent 3 (Duplicate Detector): done[m
[32m+[m[32m-- Agent 4 (Response Drafter): skipped (duplicate)[m
[32m+[m[32m-> Agent 5 (SLA Monitor): working...[m
[32m+[m[32mOK Agent 5 (SLA Monitor): done[m
[32m+[m[32mALL AGENTS FINISHED -- result below[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Batch Processing: process_all()[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32mdef process_all(limit=None, draft_response=True, progress=True):[m
[32m+[m[32m    """Process EVERY unprocessed complaint in the database"""[m
[32m+[m[41m    [m
[32m+[m[32m    # Get all unprocessed complaints[m
[32m+[m[32m    pending = db.list_unprocessed(limit=limit)  # WHERE processed_at IS NULL[m
[32m+[m[41m    [m
[32m+[m[32m    summaries = [][m
[32m+[m[32m    for i, row in enumerate(pending, 1):[m
[32m+[m[32m        try:[m
[32m+[m[32m            summaries.append(process_one(row["id"], draft_response=draft_response))[m
[32m+[m[32m        except Exception as e:[m
[32m+[m[32m            summaries.append({"id": row["id], "error": str(e)})[m
[32m+[m[41m        [m
[32m+[m[32m        # Print progress every 10 complaints[m
[32m+[m[32m        if progress and (i % 10 == 0 or i == len(pending)):[m
[32m+[m[32m            print(f"  processed {i}/{len(pending)}")[m
[32m+[m[41m    [m
[32m+[m[32m    # After ALL complaints processed, run ROOT CAUSE detection[m
[32m+[m[32m    alerts = root_cause.detect()           # KMeans clustering[m
[32m+[m[32m    root_cause.store_alerts(alerts)        # Save to database[m
[32m+[m[41m    [m
[32m+[m[32m    return {[m
[32m+[m[32m        "processed": len(summaries),[m
[32m+[m[32m        "errors": sum(1 for s in summaries if "error" in s),[m
[32m+[m[32m        "duplicates_found": sum(1 for s in summaries if s.get("is_duplicate")),[m
[32m+[m[32m        "alerts_detected": len(alerts),[m
[32m+[m[32m        "summaries": summaries,[m
[32m+[m[32m        "alerts": alerts,[m
[32m+[m[32m    }[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32mThis is what runs when you execute:[m
[32m+[m[32m```bash[m
[32m+[m[32mpython -m pipeline.orchestrator[m
[32m+[m[32m```[m
