[32m+[m
[32m+[m[32m## 6. The Vector Database: ChromaDB Explained[m
[32m+[m
[32m+[m[32m### What is ChromaDB?[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32mTraditional database: Stores exact values[m
[32m+[m[32m- SQL: "Find customer with name = 'Rahul'"[m
[32m+[m[32m- Exact match only[m
[32m+[m
[32m+[m[32mVector database: Stores semantic meaning[m
[32m+[m[32m- "Find complaints similar to 'UPI failed'"[m
[32m+[m[32m- Semantic similarity search[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### How ChromaDB Works[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32mimport chromadb[m
[32m+[m
[32m+[m[32m# Initialize persistent database[m
[32m+[m[32mclient = chromadb.PersistentClient(path="./chroma_db")[m
[32m+[m
[32m+[m[32m# Create collection with cosine similarity[m
[32m+[m[32mcollection = client.create_collection([m
[32m+[m[32m    name="complaints",[m
[32m+[m[32m    metadata={"hnsw:space": "cosine"}  # Cosine similarity[m
[32m+[m[32m)[m
[32m+[m
[32m+[m[32m# Add embeddings[m
[32m+[m[32mcollection.add([m
[32m+[m[32m    ids=["UBI-0001", "UBI-0002"],[m
[32m+[m[32m    embeddings=[[0.1, 0.2, ...], [0.3, 0.4, ...]],  # 384-dim vectors[m
[32m+[m[32m    documents=["UPI failed", "ATM blocked"],[m
[32m+[m[32m    metadatas=[[m
[32m+[m[32m        {"customer": "Rahul", "category": "UPI"},[m
[32m+[m[32m        {"customer": "Priya", "category": "ATM"}[m
[32m+[m[32m    ][m
[32m+[m[32m)[m
[32m+[m
[32m+[m[32m# Query similar documents[m
[32m+[m[32mresults = collection.query([m
[32m+[m[32m    query_embeddings=[[0.1, 0.2, ...]],[m
[32m+[m[32m    n_results=2,[m
[32m+[m[32m    where={"customer": "Rahul"}  # Filter: only same customer[m
[32m+[m[32m)[m
[32m+[m
[32m+[m[32m# Results contain IDs, distances, documents, metadatas[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Why ChromaDB over alternatives?[m
[32m+[m
[32m+[m[32m| Feature | ChromaDB | Pinecone | FAISS |[m
[32m+[m[32m|---------|----------|----------|-------|[m
[32m+[m[32m| Local/Persistent | ✅ | ❌ | ✅ |[m
[32m+[m[32m| Metadata filtering | ✅ | ✅ | ❌ (hard) |[m
[32m+[m[32m| Free | ✅ | ❌ (paid) | ✅ |[m
[32m+[m[32m| Easy setup | ✅ | ✅ | ❌ (complex) |[m
[32m+[m[32m| Python-native | ✅ | ✅ | ❌ (C++) |[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## 7. Root Cause Detection: KMeans Clustering Deep Dive[m
[32m+[m
[32m+[m[32m### What is KMeans?[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# KMeans algorithm[m
[32m+[m[32m# 1. Pick k random centroids[m
[32m+[m[32m# 2. Assign each point to nearest centroid[m
[32m+[m[32m# 3. Recalculate centroids[m
[32m+[m[32m# 4. Repeat until convergence[m
[32m+[m
[32m+[m[32mfrom sklearn.cluster import KMeans[m
[32m+[m
[32m+[m[32m# Example: Cluster 2D points[m
[32m+[m[32mpoints = [[m
[32m+[m[32m    [1, 2], [1, 4], [1, 0],    # Cluster A[m
[32m+[m[32m    [10, 2], [10, 4], [10, 0], # Cluster B[m
[32m+[m[32m][m
[32m+[m
[32m+[m[32mkmeans = KMeans(n_clusters=2, random_state=42)[m
[32m+[m[32mlabels = kmeans.fit_predict(points)[m
[32m+[m
[32m+[m[32m# labels = [0, 0, 0, 1, 1, 1]  - correctly identified![m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Application to Complaint Analysis[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# Step 1: Get all complaint embeddings[m
[32m+[m[32mall_embeddings = []  # 1000 × 384 matrix[m
[32m+[m[32mall_metadata = []    # 1000 dicts[m
[32m+[m
[32m+[m[32mfor complaint in db.list_complaints():[m
[32m+[m[32m    embedding = embed(complaint["complaint_text"])[m
[32m+[m[32m    all_embeddings.append(embedding)[m
[32m+[m[32m    all_metadata.append({[m
[32m+[m[32m        "customer": complaint["customer_name"],[m
[32m+[m[32m        "category": complaint["category"],[m
[32m+[m[32m        "location": complaint["location"][m
[32m+[m[32m    })[m
[32m+[m
[32m+[m[32m# Step 2: Run KMeans[m
[32m+[m[32mkmeans = KMeans(n_clusters=12, random_state=42)[m
[32m+[m[32mcluster_labels = kmeans.fit_predict(all_embeddings)[m
[32m+[m
[32m+[m[32m# Step 3: Analyze each cluster[m
[32m+[m[32mfor cluster_id in range(12):[m
[32m+[m[32m    # Get complaints in this cluster[m
[32m+[m[32m    cluster_mask = cluster_labels == cluster_id[m
[32m+[m[32m    cluster_complaints = [all_metadata[i] for i in range(len(cluster_labels)) if cluster_mask[i]][m
[32m+[m[41m    [m
[32m+[m[32m    # Analyze category distribution[m
[32m+[m[32m    categories = [c["category"] for c in cluster_complaints][m
[32m+[m[32m    most_common = Counter(categories).most_common(1)[0][m
[32m+[m[41m    [m
[32m+[m[32m    # If dominant category > 60%, trigger alert[m
[32m+[m[32m    if most_common[1] / len(cluster_complaints) > 0.60:[m
[32m+[m[32m        generate_alert(cluster_id, most_common[0])[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Why k=12?[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# Rule of thumb: k ≈ √(n/2)[m
[32m+[m[32m# For 1000 complaints: k ≈ √500 ≈ 22[m
[32m+[m
[32m+[m[32m# But we use k=12 because:[m
[32m+[m[32m# - Too many clusters → no dominant categories[m
[32m+[m[32m# - Too few clusters → mixing unrelated complaints[m
[32m+[m[32m# - k=12 found empirically to work well[m
[32m+[m
[32m+[m[32m# With k=12 and MIN_CLUSTER_SIZE=5:[m
[32m+[m[32m# - Minimum useful cluster: 5 complaints[m
[32m+[m[32m# - Maximum clusters with alerts: 12[m
[32m+[m[32m# - Expected meaningful alerts: 4-8[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
[32m+[m[32m## 8. Risk Score: The Weighted Formula Explained[m
[32m+[m
[32m+[m[32m### The Three Sub-Scores[m
[32m+[m
[32m+[m[32m#### 1. Ombudsman Risk (45%)[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32mdef _ombudsman_score(complaint, history, breach_prob):[m
[32m+[m[32m    score = 0[m
[32m+[m[41m    [m
[32m+[m[32m    # Base: breach probability (0-40 points)[m
[32m+[m[32m    score += breach_prob * 40[m
[32m+[m[41m    [m
[32m+[m[32m    # Severity contribution[m
[32m+[m[32m    severity_map = {"Critical": 30, "High": 20, "Medium": 10, "Low": 3}[m
[32m+[m[32m    score += severity_map.get(complaint["severity"], 10)[m
[32m+[m[41m    [m
[32m+[m[32m    # Repeat customer (0-15 points)[m
[32m+[m[32m    score += min(len(history) * 3, 15)[m
[32m+[m[41m    [m
[32m+[m[32m    # Amount stuck (0-12 points)[m
[32m+[m[32m    amount = complaint.get("amount_involved", 0)[m
[32m+[m[32m    if amount >= 100000:[m
[32m+[m[32m        score += 12[m
[32m+[m[32m    elif amount >= 25000:[m
[32m+[m[32m        score += 6[m
[32m+[m[41m    [m
[32m+[m[32m    # Angry history (0-8 points)[m
[32m+[m[32m    angry_count = sum(1 for h in history if h.get("sentiment") == "Angry")[m
[32m+[m[32m    score += min(angry_count * 2, 8)[m
[32m+[m[41m    [m
[32m+[m[32m    return min(100, int(score))[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m**Intuition:**[m
[32m+[m[32m- High breach probability → customer likely to escalate[m
[32m+[m[32m- Critical severity → already a big issue[m
[32m+[m[32m- Repeat customer → already unhappy[m
[32m+[m[32m- Large amount → more upset[m
[32m+[m[32m- Angry history → escalating pattern[m
[32m+[m
[32m+[m[32m#### 2. Churn Risk (30%)[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32mdef _churn_score(complaint, history):[m
[32m+[m[32m    score = 0[m
[32m+[m[41m    [m
[32m+[m[32m    # Number of complaints (0-30 points)[m
[32m+[m[32m    score += min(len(history) * 6, 30)[m
[32m+[m[41m    [m
[32m+[m[32m    # Unresolved issues (0-25 points)[m
[32m+[m[32m    unresolved = sum(1 for h in history if h.get("status") == "open")[m
[32m+[m[32m    score += min(unresolved * 5, 25)[m
[32m+[m[41m    [m
[32m+[m[32m    # Category breadth (0-20 points)[m
[32m+[m[32m    categories = set(h.get("category") for h in history)[m
[32m+[m[32m    score += min(len(categories) * 6, 20)[m
[32m+[m[41m    [m
[32m+[m[32m    # Current sentiment[m
[32m+[m[32m    if complaint.get("sentiment") in ["Angry", "Frustrated"]:[m
[32m+[m[32m        score += 12[m
[32m+[m[41m    [m
[32m+[m[32m    # Current severity[m
[32m+[m[32m    if complaint.get("severity") in ["Critical", "High"]:[m
[32m+[m[32m        score += 8[m
[32m+[m[41m    [m
[32m+[m[32m    return min(100, int(score))[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m**Intuition:**[m
[32m+[m[32m- Multiple complaints → unhappy customer[m
[32m+[m[32m- Unresolved issues → not getting help[m
[32m+[m[32m- Many categories → systemic problems[m
[32m+[m[32m- Angry/frustrated → might leave[m
[32m+[m[32m- High severity → urgent attention needed[m
[32m+[m
[32m+[m[32m#### 3. Social Media Risk (25%)[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32mdef _social_score(complaint, history):[m
[32m+[m[32m    score = 0[m
[32m+[m[41m    [m
[32m+[m[32m    # Past public complaints (0-45 points)[m
[32m+[m[32m    public_channels = {"twitter", "whatsapp"}[m
[32m+[m[32m    public_complaints = [h for h in history if h.get("channel") in public_channels][m
[32m+[m[32m    score += min(len(public_complaints) * 12, 45)[m
[32m+[m[41m    [m
[32m+[m[32m    # Current public channel[m
[32m+[m[32m    if complaint.get("channel") in public_channels:[m
[32m+[m[32m        score += 18[m
[32m+[m[41m    [m
[32m+[m[32m    # Current sentiment[m
[32m+[m[32m    sentiment_map = {"Angry": 22, "Frustrated": 10}[m
[32m+[m[32m    score += sentiment_map.get(complaint.get("sentiment"), 0)[m
[32m+[m[41m    [m
[32m+[m[32m    # Current severity[m
[32m+[m[32m    if complaint.get("severity") == "Critical":[m
[32m+[m[32m        score += 8[m
[32m+[m[41m    [m
[32m+[m[32m    return min(100, int(score))[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m**Intuition:**[m
[32m+[m[32m- Twitter/WhatsApp complaints are public[m
[32m+[m[32m- Public complaints damage reputation[m
[32m+[m[32m- Angry sentiment on public channel → viral risk[m
[32m+[m[32m- Critical severity → high visibility[m
[32m+[m
[32m+[m[32m### Weighted Overall[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32mdef compute_overall(ombudsman, churn, social):[m
[32m+[m[32m    overall = 0.45 * ombudsman + 0.30 * churn + 0.25 * social[m
[32m+[m[32m    return int(min(100, max(0, overall)))[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m**Why these weights?**[m
[32m+[m[32m- **Ombudsman (45%)**: Regulatory risk is highest priority[m
[32m+[m[32m- **Churn (30%)**: Customer retention is important[m
[32m+[m[32m- **Social (25%)**: Reputation risk, but less controllable[m
[32m+[m
