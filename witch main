[32m+[m[32m## 18. The RBI Report Generator[m
[32m+[m
[32m+[m[32m### What is RBI Compliance?[m
[32m+[m
[32m+[m[32mThe Reserve Bank of India (RBI) requires banks to submit **compliance reports** showing:[m
[32m+[m[32m- How many complaints received[m
[32m+[m[32m- How many resolved within SLA[m
[32m+[m[32m- How many breached[m
[32m+[m[32m- Details of each complaint[m
[32m+[m
[32m+[m[32mThis is a **legal requirement** - banks can be penalized for incorrect reports.[m
[32m+[m
[32m+[m[32m### Report Generation[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# dashboard/rbi_report.py[m
[32m+[m
[32m+[m[32mREPORT_COLUMNS = [[m
[32m+[m[32m    "Complaint ID", "Customer Name", "Type", "Severity", "Channel",[m
[32m+[m[32m    "Date Filed", "SLA Deadline", "Days Remaining",[m
[32m+[m[32m    "Breach Status", "Resolution Status",[m
[32m+[m[32m][m
[32m+[m
[32m+[m
[32m+[m[32mdef build_report(rows, today=None):[m
[32m+[m[32m    """Convert database rows to RBI-compliant format"""[m
[32m+[m[41m    [m
[32m+[m[32m    today_ts = pd.Timestamp(today or date.today())[m
[32m+[m[32m    df = pd.DataFrame(rows)[m
[32m+[m[41m    [m
[32m+[m[32m    # Calculate breach status[m
[32m+[m[32m    def _breach_status(due_date, breach_prob):[m
[32m+[m[32m        if due_date < today_ts:[m
[32m+[m[32m            return "Breached"[m
[32m+[m[32m        if breach_prob and breach_prob >= 0.5:[m
[32m+[m[32m            return "At Risk"[m
[32m+[m[32m        return "On Track"[m
[32m+[m[41m    [m
[32m+[m[32m    # Calculate resolution status[m
[32m+[m[32m    def _resolution_status(row):[m
[32m+[m[32m        status = row.get("status", "open")[m
[32m+[m[32m        if status == "resolved": return "Resolved"[m
[32m+[m[32m        if status == "auto_resolved_dup": return "Auto-Resolved (Duplicate)"[m
[32m+[m[32m        if status == "auto_resolved_std": return "Auto-Resolved (Standard)"[m
[32m+[m[41m        [m
[32m+[m[32m        due = row.get("sla_due_date")[m
[32m+[m[32m        if due and due < today_ts:[m
[32m+[m[32m            return "Breached"[m
[32m+[m[32m        return "Pending"[m
[32m+[m[41m    [m
[32m+[m[32m    return pd.DataFrame({[m
[32m+[m[32m        "Complaint ID": df["id"],[m
[32m+[m[32m        "Customer Name": df["customer_name"],[m
[32m+[m[32m        "Type": df["category"].fillna("General"),[m
[32m+[m[32m        "Severity": df["severity"].fillna("Medium"),[m
[32m+[m[32m        "Channel": df["channel"],[m
[32m+[m[32m        "Date Filed": df["date"],[m
[32m+[m[32m        "SLA Deadline": df["sla_due_date"],[m
[32m+[m[32m        "Days Remaining": (df["sla_due_date"] - today_ts).dt.days,[m
[32m+[m[32m        "Breach Status": [_breach_status(d, p) for d, p in zip(df["sla_due_date"], df["sla_breach_prob"])],[m
[32m+[m[32m        "Resolution Status": [_resolution_status(r) for _, r in df.iterrows()],[m
[32m+[m[32m    })[REPORT_COLUMNS][m
[32m+[m
[32m+[m
[32m+[m[32mdef to_csv(rows, today=None):[m
[32m+[m[32m    """Generate downloadable CSV"""[m
[32m+[m[32m    df = build_report(rows, today)[m
[32m+[m[32m    buf = StringIO()[m
[32m+[m[32m    df.to_csv(buf, index=False)[m
[32m+[m[32m    return buf.getvalue().encode("utf-8-sig")  # BOM for Excel Hindi support[m
[32m+[m[32m```[m
