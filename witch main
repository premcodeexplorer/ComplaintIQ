[32m+[m[32m## 4. Deep Dive: Each Agent Explained[m
[32m+[m
[32m+[m[32m### Agent 1: INTAKE - The Information Extractor[m
[32m+[m
[32m+[m[32m#### What it does[m
[32m+[m
[32m+[m[32mTakes raw complaint text and extracts structured information:[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# Input[m
[32m+[m[32mraw_complaint = {[m
[32m+[m[32m    "complaint_text": "मेरा UPI payment fail हो गया है, 5000 rupees debited हो गए",[m
[32m+[m[32m    "channel": "whatsapp",[m
[32m+[m[32m    "language": "hindi"[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32m# Output[m
[32m+[m[32mintake_output = {[m
[32m+[m[32m    "customer_name": None,           # Not in text[m
[32m+[m[32m    "issue_summary": "UPI payment failed, amount debited",[m
[32m+[m[32m    "account_type": "savings",       # Guessed[m
[32m+[m[32m    "amount_involved": 5000,[m
[32m+[m[32m    "transaction_id": None,[m
[32m+[m[32m    "location_mentioned": None,[m
[32m+[m[32m    "urgency_keywords": ["fail", "stuck", "debited"],[m
[32m+[m[32m    "detected_language": "hindi"[m
[32m+[m[32m}[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m#### Why Use LLM for This?[m
[32m+[m
[32m+[m[32m**Traditional approach:**[m
[32m+[m[32m```python[m
[32m+[m[32m# Regex-based extraction[m
[32m+[m[32mimport re[m
[32m+[m
[32m+[m[32mdef extract_amount(text):[m
[32m+[m[32m    match = re.search(r'(\d+)\s*(?:rupees|rs\.?|INR)', text, re.IGNORECASE)[m
[32m+[m[32m    return int(match.group(1)) if match else None[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m**Problems with regex:**[m
[32m+[m[32m- Can't handle: "five thousand rupees", "₹5000"[m
[32m+[m[32m- Can't extract: issue_summary (requires understanding)[m
[32m+[m[32m- Can't detect: urgency_keywords, sentiment[m
[32m+[m[32m- Language-specific rules needed[m
[32m+[m
[32m+[m[32m**LLM approach:**[m
[32m+[m[32m- Understands context[m
[32m+[m[32m- Handles any language[m
[32m+[m[32m- Extracts multiple fields at once[m
[32m+[m[32m- Learns from examples[m
[32m+[m
[32m+[m[32m#### The Prompt Engineering[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32mSYSTEM = """[m
[32m+[m[32mYou are an intake agent for an Indian bank's complaint system.[m
[32m+[m[32mYou receive raw customer complaints in English, Hindi or Marathi[m
[32m+[m[32m(often code-mixed) and return a JSON object with normalized fields.[m
[32m+[m[32mBe conservative: if a field is not present, return null. Do NOT invent values.[m
[32m+[m[32m"""[m
[32m+[m
[32m+[m[32mPROMPT_TEMPLATE = """[m
[32m+[m[32mExtract a structured complaint record from the message below.[m
[32m+[m
[32m+[m[32mReturn ONLY a JSON object with these exact keys (use null for unknown):[m
[32m+[m[32m{{[m
[32m+[m[32m  "customer_name": string or null,[m
[32m+[m[32m  "issue_summary": short one-sentence summary in English,[m
[32m+[m[32m  "account_type": one of ["savings", "current", "credit_card", "loan", "demat", null],[m
[32m+[m[32m  "amount_involved": number (INR, no commas) or null,[m
[32m+[m[32m  "transaction_id": string or null,[m
[32m+[m[32m  "location_mentioned": string or null,[m
[32m+[m[32m  "urgency_keywords": list of strings (e.g. ["urgent","blocked","unable"]) or [],[m
[32m+[m[32m  "detected_language": one of ["english","hindi","marathi","mixed"][m
[32m+[m[32m}}[m
[32m+[m
[32m+[m[32mChannel: {channel}[m
[32m+[m[32mKnown customer name (may be empty): {customer_name}[m
[32m+[m
[32m+[m[32mComplaint text:[m
[32m+[m[32m\"\"\"{text}\"\"\"[m
[32m+[m[32m"""[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m**Key prompt elements:**[m
[32m+[m[32m1. **Output format specification** - exact JSON keys[m
[32m+[m[32m2. **Conservative instruction** - don't invent values[m
[32m+[m[32m3. **Language support** - handles multilingual[m
[32m+[m[32m4. **Context** - channel, customer name as hints[m
[32m+[m
[32m+[m[32m#### The Code Flow[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# agents/intake.py - Simplified flow[m
[32m+[m
[32m+[m[32mdef extract(raw: dict[str, Any]) -> dict[str, Any]:[m
[32m+[m[32m    text = raw.get("complaint_text") or ""[m
[32m+[m[41m    [m
[32m+[m[32m    # Build prompt with context[m
[32m+[m[32m    prompt = PROMPT_TEMPLATE.format([m
[32m+[m[32m        channel=raw.get("channel", "unknown"),[m
[32m+[m[32m        customer_name=raw.get("customer_name", "") or "",[m
[32m+[m[32m        text=text,[m
[32m+[m[32m    )[m
[32m+[m[41m    [m
[32m+[m[32m    try:[m
[32m+[m[32m        # Call LLM - returns JSON[m
[32m+[m[32m        data = chat_json(prompt, system=SYSTEM, temperature=0.0)[m
[32m+[m[32m    except Exception as e:[m
[32m+[m[32m        # Fallback if LLM fails[m
[32m+[m[32m        return _fallback(raw, error=str(e))[m
[32m+[m[41m    [m
[32m+[m[32m    # Normalize and merge with caller-provided fields[m
[32m+[m[32m    # (caller-provided fields win - they're source of truth)[m
[32m+[m[32m    out = {k: data.get(k) for k in EXPECTED_KEYS}[m
[32m+[m[32m    if not out.get("customer_name") and raw.get("customer_name"):[m
[32m+[m[32m        out["customer_name"] = raw["customer_name"][m
[32m+[m[41m    [m
[32m+[m[32m    return out[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m---[m
[32m+[m
