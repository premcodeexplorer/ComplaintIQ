[32m+[m
[32m+[m[32m#### Why Use Sentence Transformers?[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# The model: all-MiniLM-L6-v2[m
[32m+[m[32m#[m[41m [m
[32m+[m[32m# Why this model?[m
[32m+[m[32m# 1. Fast: Optimized for speed[m
[32m+[m[32m# 2. Small: 384 dimensions vs 768/1024 in larger models[m
[32m+[m[32m# 3. Good quality: Good enough for duplicate detection[m
[32m+[m[32m# 4. Pre-trained: Already knows language semantics[m
[32m+[m
[32m+[m[32m# Example embeddings:[m
[32m+[m[32mtext1 = "UPI payment failed"[m
[32m+[m[32mtext2 = "UPI payment not working"[m[41m [m
[32m+[m[32mtext3 = "ATM card is blocked"[m
[32m+[m
[32m+[m[32m# These are CLOSE (same category):[m
[32m+[m[32mprint(cosine_similarity(embed(text1), embed(text2)))  # ~0.82[m
[32m+[m
[32m+[m[32m# These are FAR (different category):[m
[32m+[m[32mprint(cosine_similarity(embed(text1), embed(text3)))  # ~0.45[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m#### The ChromaDB Setup[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# agents/duplicate_detector.py[m
[32m+[m
[32m+[m[32mCHROMA_DIR = Path("data/chroma_db")[m
[32m+[m[32mMODEL_NAME = "all-MiniLM-L6-v2"[m
[32m+[m[32mDUP_THRESHOLD = 0.78  # cosine similarity[m
[32m+[m
[32m+[m[32mdef _get_collection():[m
[32m+[m[32m    import chromadb[m
[32m+[m[41m    [m
[32m+[m[32m    CHROMA_DIR.mkdir(parents=True, exist_ok=True)[m
[32m+[m[32m    client = chromadb.PersistentClient(path=str(CHROMA_DIR))[m
[32m+[m[41m    [m
[32m+[m[32m    # Cosine similarity space[m
[32m+[m[32m    collection = client.get_or_create_collection([m
[32m+[m[32m        name="complaints",[m
[32m+[m[32m        metadata={"hnsw:space": "cosine"}[m
[32m+[m[32m    )[m
[32m+[m[32m    return collection[m
[32m+[m
[32m+[m[32mdef find_duplicate(complaint):[m
[32m+[m[32m    # 1. Embed the new complaint[m
[32m+[m[32m    text = complaint.get("complaint_text", "") or ""[m
[32m+[m[32m    query_vector = embed(text)[m
[32m+[m[41m    [m
[32m+[m[32m    # 2. Search ONLY same customer[m
[32m+[m[32m    customer = complaint.get("customer_name") or ""[m
[32m+[m[41m    [m
[32m+[m[32m    # 3. Query ChromaDB[m
[32m+[m[32m    results = collection.query([m
[32m+[m[32m        query_embeddings=[query_vector],[m
[32m+[m[32m        n_results=5,[m
[32m+[m[32m        where={"customer_name": customer}  # Filter by customer[m
[32m+[m[32m    )[m
[32m+[m[41m    [m
[32m+[m[32m    # 4. Find best match[m
[32m+[m[32m    best_similarity = 0[m
[32m+[m[32m    best_id = None[m
[32m+[m[41m    [m
[32m+[m[32m    for id, distance in zip(results["ids"][0], results["distances"][0]):[m
[32m+[m[32m        if id == complaint.get("id"):[m
[32m+[m[32m            continue  # Don't match self[m
[32m+[m[32m        similarity = 1 - distance  # Convert distance to similarity[m
[32m+[m[32m        if similarity > best_similarity:[m
[32m+[m[32m            best_similarity = similarity[m
[32m+[m[32m            best_id = id[m
[32m+[m[41m    [m
[32m+[m[32m    # 5. Return result[m
[32m+[m[32m    is_duplicate = best_similarity >= DUP_THRESHOLD[m
[32m+[m[41m    [m
[32m+[m[32m    return {[m
[32m+[m[32m        "is_duplicate": is_duplicate,[m
[32m+[m[32m        "duplicate_of": best_id if is_duplicate else None,[m
[32m+[m[32m        "similarity": round(best_similarity, 4)[m
[32m+[m[32m    }[m
[32m+[m[32m```[m
