[32m+[m[32m### Database Operations[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# --- Reading Data ---[m
[32m+[m
[32m+[m[32mdef get_complaint(complaint_id: str):[m
[32m+[m[32m    """Get ONE complaint by ID"""[m
[32m+[m[32m    with connect() as c:[m
[32m+[m[32m        row = c.execute("SELECT * FROM complaints WHERE id = ?", (complaint_id,)).fetchone()[m
[32m+[m[32m    return dict(row) if row else None[m
[32m+[m
[32m+[m
[32m+[m[32mdef list_complaints(limit=None, where=None, params=()):[m
[32m+[m[32m    """List ALL complaints, optionally filtered"""[m
[32m+[m[32m    q = "SELECT * FROM complaints"[m
[32m+[m[32m    if where:[m
[32m+[m[32m        q += " WHERE " + where[m
[32m+[m[32m    q += " ORDER BY date DESC"[m
[32m+[m[32m    if limit:[m
[32m+[m[32m        q += f" LIMIT {limit}"[m
[32m+[m[41m    [m
[32m+[m[32m    with connect() as c:[m
[32m+[m[32m        rows = c.execute(q, tuple(params)).fetchall()[m
[32m+[m[32m    return [dict(r) for r in rows][m
[32m+[m
[32m+[m
[32m+[m[32mdef list_unprocessed(limit=None):[m
[32m+[m[32m    """Get complaints that haven't been through the pipeline"""[m
[32m+[m[32m    return list_complaints(limit=limit, where="processed_at IS NULL")[m
[32m+[m
[32m+[m
[32m+[m[32mdef customer_history(customer_name: str):[m
[32m+[m[32m    """Get all complaints from ONE customer"""[m
[32m+[m[32m    return list_complaints(where="customer_name = ?", params=(customer_name,))[m
[32m+[m
[32m+[m
[32m+[m[32m# --- Writing Data ---[m
[32m+[m
[32m+[m[32mdef update_complaint(complaint_id: str, **fields):[m
[32m+[m[32m    """Update a complaint with new values"""[m
[32m+[m[41m    [m
[32m+[m[32m    set_clause = ", ".join(f"{k} = ?" for k in fields)[m
[32m+[m[32m    vals = list(fields.values()) + [complaint_id][m
[32m+[m[41m    [m
[32m+[m[32m    with connect() as c:[m
[32m+[m[32m        c.execute(f"UPDATE complaints SET {set_clause} WHERE id = ?", vals)[m
[32m+[m
[32m+[m
[32m+[m[32mdef record_feedback(complaint_id, field, original, corrected, is_correct):[m
[32m+[m[32m    """Record human feedback on classification"""[m
[32m+[m[41m    [m
[32m+[m[32m    with connect() as c:[m
[32m+[m[32m        c.execute([m
[32m+[m[32m            "INSERT INTO feedback (complaint_id, field, original_value, "[m
[32m+[m[32m            "corrected_value, is_correct, created_at) VALUES (?, ?, ?, ?, ?, ?)",[m
[32m+[m[32m            (complaint_id, field, original, corrected, 1 if is_correct else 0,[m[41m [m
[32m+[m[32m             datetime.utcnow().isoformat())[m
[32m+[m[32m        )[m
[32m+[m[41m    [m
[32m+[m[32m    # If corrected, also update the complaint[m
[32m+[m[32m    if not is_correct and corrected:[m
[32m+[m[32m        update_complaint(complaint_id, **{field: corrected})[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Context Manager for Connections[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# database/db.py[m
[32m+[m
[32m+[m[32m@contextmanager[m
[32m+[m[32mdef connect():[m
[32m+[m[32m    """Connect to SQLite, auto-commit on success"""[m
[32m+[m[32m    DB_PATH.parent.mkdir(parents=True, exist_ok=True)[m
[32m+[m[32m    conn = sqlite3.connect(DB_PATH)[m
[32m+[m[32m    conn.row_factory = sqlite3.Row  # Access columns by name[m
[32m+[m[32m    try:[m
[32m+[m[32m        yield conn[m
[32m+[m[32m        conn.commit()  # Save changes[m
[32m+[m[32m    finally:[m
[32m+[m[32m        conn.close()   # Always close[m
[32m+[m
[32m+[m[32m# Usage:[m
[32m+[m[32mwith connect() as c:[m
[32m+[m[32m    c.execute("SELECT * FROM complaints WHERE id = ?", ("UBI-0001",))[m
[32m+[m[32m    # Changes automatically committed when exiting the with block[m
[32m+[m[32m```[m
