[32m+[m[32m│                     YES ╱          │          ╲ NO                             │[m
[32m+[m[32m│                   ┌────┴────┐      │      ┌────┴────┐                          │[m
[32m+[m[32m│                   │ severity │      │      │ is_duplicate? │                  │[m
[32m+[m[32m│                   │ =Critical?      │      └────┬────┘                          │[m
