[32m+[m[32m### Agent 3: DUPLICATE DETECTOR - The Semantic Matcher[m
[32m+[m
[32m+[m[32m#### The Problem with Simple Matching[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32mComplaint 1: "UPI payment failed"[m
[32m+[m[32mComplaint 2: "UPI payment not working"[m
[32m+[m
[32m+[m[32mSimple match: Different (no exact match)[m
[32m+[m[32mSemantic match: Same (meaning is similar)[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m#### How Semantic Search Works[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32m┌─────────────────────────────────────────────────────────────────────────┐[m
[32m+[m[32m│                    SEMANTIC SEARCH PROCESS                              │[m
[32m+[m[32m├─────────────────────────────────────────────────────────────────────────┤[m
[32m+[m[32m│                                                                         │[m
[32m+[m[32m│  Step 1: CONVERT TEXT TO VECTOR                                        │[m
[32m+[m[32m│  ────────────────────────────                                          │[m
[32m+[m[32m│                                                                         │[m
[32m+[m[32m│  Text: "UPI payment failed"                                           │[m
