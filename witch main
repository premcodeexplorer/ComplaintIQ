[32m+[m[32m## 13. The Orchestrator: The Pipeline Conductor[m
[32m+[m
[32m+[m[32m### What is an Orchestrator?[m
[32m+[m
[32m+[m[32mThink of the orchestrator as the **conductor of an orchestra**. Each agent (agents) is a different musician - they all have their own instruments (capabilities), but without a conductor, they can't play together in harmony.[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32mWithout Orchestrator:[m
[32m+[m[32m─────────────────────[m
[32m+[m[32mIntake Agent     → "Here's some data"[m
[32m+[m[32mClassifier      → "I need input in a specific format"[m
[32m+[m[32mDuplicate       → "What am I searching for?"[m
[32m+[m[32mResponse Drafter → "When do I start?"[m
[32m+[m[32mSLA Monitor      → "What category is this?"[m
[32m+[m
[32m+[m[32mEVERY AGENT DOES ITS OWN THING, NO COORDINATION = CHAOS[m
[32m+[m
[32m+[m[32mWith Orchestrator:[m
[32m+[m[32m──────────────────[m
[32m+[m[32mOrchestrator → "First, Intake, extract fields from this complaint"[m
[32m+[m[32m           → "Good. Now Classifier, categorize it using that extracted data"[m
[32m+[m[32m           → "Great. Duplicate Detector, check for matches using the same text"[m
[32m+[m[32m           → "Since it's not a duplicate, Response Drafter, write a reply"[m
[32m+[m[32m           → "Finally, SLA Monitor, calculate deadline and risk"[m
[32m+[m[32m           → "Now save everything to the database"[m
[32m+[m
[32m+[m[32mALL AGENTS WORK TOGETHER IN ORDER = HARMONY[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### The Orchestrator Code Flow[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# pipeline/orchestrator.py - Simplified process_one_streaming()[m
[32m+[m
[32m+[m[32mdef process_one_streaming(complaint_id: str, on_step=None):[m
[32m+[m[32m    """Process ONE complaint through ALL 6 agents sequentially"""[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 1: Get the raw complaint from database[m
[32m+[m[32m    row = db.get_complaint(complaint_id)  # e.g., UBI-0001[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 2: AGENT 1 - INTAKE[m
[32m+[m[32m    # Purpose: Extract structured information from raw text[m
[32m+[m[32m    emit("Agent 1 (Intake)", "started")[m
[32m+[m[32m    intake_out = intake.extract(row)  # Returns: {customer_name, amount, etc.}[m
[32m+[m[32m    emit("Agent 1 (Intake)", "done", intake_out)[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 3: AGENT 2 - CLASSIFIER[m
[32m+[m[32m    # Purpose: Assign category, severity, sentiment[m
[32m+[m[32m    emit("Agent 2 (Classifier)", "started")[m
[32m+[m[32m    cls = classifier.classify(row)     # Returns: {category, severity, sentiment}[m
[32m+[m[32m    row.update(cls)  # Add classification to the row[m
[32m+[m[32m    emit("Agent 2 (Classifier)", "done", cls)[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 4: AGENT 3 - DUPLICATE DETECTOR[m
[32m+[m[32m    # Purpose: Find similar prior complaints from same customer[m
[32m+[m[32m    emit("Agent 3 (Duplicate Detector)", "started")[m
[32m+[m[32m    dup = dd.find_duplicate(row)  # Returns: {is_duplicate, duplicate_of, similarity}[m
[32m+[m[32m    emit("Agent 3 (Duplicate Detector)", "done", dup)[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 5: AGENT 4 - RESPONSE DRAFTER (Conditional)[m
[32m+[m[32m    # Purpose: Generate bank response[m
[32m+[m[32m    if dup["is_duplicate"]:[m
[32m+[m[32m        # Skip - don't generate new response for duplicates[m
[32m+[m[32m        draft = None[m
[32m+[m[32m        emit("Agent 4 (Response Drafter)", "skipped", None)[m
[32m+[m[32m    else:[m
[32m+[m[32m        emit("Agent 4 (Response Drafter)", "started")[m
[32m+[m[32m        draft = response_drafter.draft(row, sla_days=4)[m
[32m+[m[32m        emit("Agent 4 (Response Drafter)", "done", {"draft": draft})[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 6: AGENT 5 - SLA MONITOR[m
[32m+[m[32m    # Purpose: Calculate deadline and breach probability[m
[32m+[m[32m    emit("Agent 5 (SLA Monitor)", "started")[m
[32m+[m[32m    sla = sla_monitor.predict_breach(row)[m
[32m+[m[32m    row["sla_breach_prob"] = sla["breach_probability"][m
[32m+[m[32m    row["duplicate_of"] = dup["duplicate_of"][m
[32m+[m[32m    emit("Agent 5 (SLA Monitor)", "done", sla)[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 7: ML SECOND OPINIONS[m
[32m+[m[32m    # Purpose: Verify LLM classifications with independent models[m
[32m+[m[41m    [m
[32m+[m[32m    # ML Category (TF-IDF + Logistic Regression)[m
[32m+[m[32m    emit("ML Category (TF-IDF + LogReg)", "started")[m
[32m+[m[32m    ml_cat = ml_category.predict(row.get("complaint_text") or "")[m
[32m+[m[32m    cat_conf = ml_category.agreement(cls.get("category"), ml_cat["category"])[m
[32m+[m[32m    emit("ML Category (TF-IDF + LogReg)", "done", {**ml_cat, "agreement": cat_conf})[m
[32m+[m[41m    [m
[32m+[m[32m    # ML Sentiment (RoBERTa)[m
[32m+[m[32m    emit("ML Sentiment (HF Roberta)", "started")[m
[32m+[m[32m    ml_sent = sentiment_ml.predict(row.get("complaint_text") or "")[m
[32m+[m[32m    sent_conf = sentiment_ml.agreement(cls.get("sentiment"), ml_sent)[m
[32m+[m[32m    emit("ML Sentiment (HF Roberta)", "done", {**ml_sent, "agreement": sent_conf})[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 8: COMPUTE RISK AND PRIORITY[m
[32m+[m[32m    # Purpose: Calculate customer risk score and priority[m
[32m+[m[41m    [m
[32m+[m[32m    history = db.customer_history(row.get("customer_name") or "")[m
[32m+[m[32m    risk = risk_module.compute(row, history, breach_prob=sla["breach_probability"])[m
[32m+[m[41m    [m
[32m+[m[32m    emit("ML Priority (Gradient Boosting)", "started")[m
[32m+[m[32m    priority = priority_module.score({**row, "sla_breach_prob": sla["breach_probability"]})[m
[32m+[m[32m    emit("ML Priority (Gradient Boosting)", "done", {"priority_score": priority})[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 9: AUTO-RESOLUTION LOGIC[m
[32m+[m[32m    # Purpose: Decide if complaint can be auto-resolved[m
[32m+[m[41m    [m
[32m+[m[32m    if dup["is_duplicate"]:[m
[32m+[m[32m        status_value = "auto_resolved_dup"[m
[32m+[m[32m    elif (cls["severity"] in ("Low", "Medium")[m
[32m+[m[32m          and cls["sentiment"] == "Polite"[m
[32m+[m[32m          and cls["category"] in ("UPI", "ATM", "Card", "NetBanking", "Loan", "General")):[m
[32m+[m[32m        status_value = "auto_resolved_std"[m
[32m+[m[32m    else:[m
[32m+[m[32m        status_value = "open"[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 10: SAVE TO DATABASE[m
[32m+[m[32m    db.update_complaint([m
[32m+[m[32m        complaint_id,[m
[32m+[m[32m        category=cls["category"],[m
[32m+[m[32m        severity=cls["severity"],[m
[32m+[m[32m        sentiment=cls["sentiment"],[m
[32m+[m[32m        # ... many more fields[m
[32m+[m[32m        status=status_value,[m
[32m+[m[32m        processed_at=datetime.utcnow().isoformat() + "Z",[m
[32m+[m[32m    )[m
[32m+[m[41m    [m
[32m+[m[32m    # STEP 11: INDEX FOR FUTURE DUPLICATE DETECTION[m
[32m+[m[32m    # Add this complaint to ChromaDB so future complaints can find it[m
[32m+[m[32m    dd.index_complaint(row)[m
[32m+[m[41m    [m
[32m+[m[32m    return {[m
[32m+[m[32m        "id": complaint_id,[m
[32m+[m[32m        "intake": intake_out,[m
[32m+[m[32m        "classification": cls,[m
[32m+[m[32m        "duplicate": dup,[m
[32m+[m[32m        "draft_response": draft,[m
[32m+[m[32m        "sla": sla,[m
[32m+[m[32m        "risk": risk,[m
[32m+[m[32m        # ...[m
[32m+[m[32m    }[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Why Streaming Callback (`on_step`)?[m
[32m+[m
[32m+[m[32mThe `on_step` parameter lets the **Dashboard show live progress**:[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# How the dashboard uses on_step[m
[32m+[m
[32m+[m[32mdef on_step(label, status, payload):[m
[32m+[m[32m    """Called after each agent completes"""[m
[32m+[m[32m    if status == "started":[m
[32m+[m[32m        agent_lines.append(f"-> {label}: working...")[m
[32m+[m[32m    elif status == "skipped":[m
[32m+[m[32m        agent_lines.append(f"-- {label}: skipped (duplicate)")[m
[32m+[m[32m    elif status == "done":[m
[32m+[m[32m        agent_lines[-1] = f"OK {label}: done"[m
[32m+[m[41m    [m
[32m+[m[32m    # Update the UI immediately[m
[32m+[m[32m    status_box.markdown("\n".join(agent_lines))[m
[32m+[m[32m    progress_bar.progress(min(step_count["i"] / 6, 1.0))[m
[32m+[m
[32m+[m[32m# Run pipeline with live updates[m
[32m+[m[32mresult = process_one_streaming("UBI-0001", on_step=on_step)[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32mThis creates this visual in the dashboard:[m
