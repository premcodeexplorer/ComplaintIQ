[32m+[m[32m┌─────────────────────────────────────┐[m
[32m+[m[32m│  Database Server                    │[m
[32m+[m[32m│  ┌─────────────────────────────┐   │[m
[32m+[m[32m│  │ complaintiq database        │   │[m
[32m+[m[32m│  └─────────────────────────────┘   │[m
[32m+[m[32m└─────────────────────────────────────┘[m
[32m+[m[32m        ↑ Needs separate server[m
[32m+[m
[32m+[m[32mSQLite:[m
[32m+[m[32m┌─────────────────────────────────────┐[m
[32m+[m[32m│  complaintiq.sqlite (file)          │[m
[32m+[m[32m│  ┌─────────────────────────────┐   │[m
[32m+[m[32m│  │ complaints table            │   │[m
[32m+[m[32m│  │ root_cause_alerts table     │   │[m
[32m+[m[32m│  │ feedback table             │   │[m
[32m+[m[32m│  └─────────────────────────────┘   │[m
[32m+[m[32m└─────────────────────────────────────┘[m
[32m+[m[32m        ↑ Just a file![m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### The Database Schema[m
