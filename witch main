[32m+[m[32m## 15. The LLM Client: Groq Integration[m
[32m+[m
[32m+[m[32m### What is Groq?[m
[32m+[m
[32m+[m[32mGroq is an **AI inference platform** that provides fast access to Large Language Models (LLMs). It's like a super-fast AI brain that can understand and generate text.[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32mComplaintIQ           Groq (Cloud)              LLM (Llama 3.3)[m
[32m+[m[32m    │                      │                         │[m
[32m+[m[32m    │─── "Classify this" ─→│                         │[m
[32m+[m[32m    │                      │─── "Here are the results"→│[m
[32m+[m[32m    │←──────────────────────│                         │[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Why Groq Instead of OpenAI?[m
[32m+[m
[32m+[m[32m| Factor | Groq (Llama 3.3) | OpenAI (GPT-4) |[m
[32m+[m[32m|--------|-----------------|----------------|[m
[32m+[m[32m| Speed | ~500ms | ~3000ms |[m
[32m+[m[32m| Cost | Free tier | Expensive |[m
[32m+[m[32m| Quality | Good | Best |[m
[32m+[m[32m| Setup | Easy | Easy |[m
[32m+[m
[32m+[m[32m**Groq wins** for this project because:[m
[32m+[m[32m1. **Fast** - 6x faster than GPT-4[m
[32m+[m[32m2. **Free** - Free tier is sufficient[m
[32m+[m[32m3. **Good enough** - Quality meets requirements[m
[32m+[m
[32m+[m[32m### The LLM Client Code[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# agents/llm_client.py[m
[32m+[m
[32m+[m[32mDEFAULT_MODEL = "llama-3.3-70b-versatile"[m
[32m+[m
[32m+[m[32mdef get_client():[m
[32m+[m[32m    """Get or create the Groq client"""[m
[32m+[m[32m    global _client[m
[32m+[m[32m    if _client is not None:[m
[32m+[m[32m        return _client[m
[32m+[m[41m    [m
[32m+[m[32m    api_key = _get_api_key()  # Try multiple sources[m
[32m+[m[32m    from groq import Groq[m
[32m+[m[32m    _client = Groq(api_key=api_key)[m
[32m+[m[32m    return _client[m
[32m+[m
[32m+[m
[32m+[m[32mdef _get_api_key() -> str:[m
[32m+[m[32m    """Try to get API key from multiple sources"""[m
[32m+[m[32m    # 1. Environment variable[m
[32m+[m[32m    key = os.getenv("GROQ_API_KEY")[m
[32m+[m[32m    if key:[m
[32m+[m[32m        return key[m
[32m+[m[41m    [m
[32m+[m[32m    # 2. Streamlit secrets (for dashboard)[m
[32m+[m[32m    import streamlit as st[m
[32m+[m[32m    if "GROQ_API_KEY" in st.secrets:[m
[32m+[m[32m        return st.secrets["GROQ_API_KEY"][m
[32m+[m[41m    [m
[32m+[m[32m    # 3. .env file (via python-dotenv)[m
[32m+[m[32m    raise RuntimeError("GROQ_API_KEY not set")[m
[32m+[m
[32m+[m
[32m+[m[32mdef chat(prompt: str, system: str = None, temperature: float = 0.2):[m
[32m+[m[32m    """Make a chat request to Groq"""[m
[32m+[m[41m    [m
[32m+[m[32m    messages = [][m
[32m+[m[32m    if system:[m
[32m+[m[32m        messages.append({"role": "system", "content": system})[m
[32m+[m[32m    messages.append({"role": "user", "content": prompt})[m
[32m+[m[41m    [m
[32m+[m[32m    client = get_client()[m
[32m+[m[32m    response = client.chat.completions.create([m
[32m+[m[32m        model=DEFAULT_MODEL,[m
[32m+[m[32m        messages=messages,[m
[32m+[m[32m        temperature=temperature,[m
[32m+[m[32m        max_tokens=800,[m
[32m+[m[32m    )[m
[32m+[m[41m    [m
[32m+[m[32m    return response.choices[0].message.content[m
[32m+[m
[32m+[m
[32m+[m[32mdef chat_json(prompt: str, system: str = None, temperature: float = 0.1):[m
[32m+[m[32m    """Make a chat request expecting JSON response"""[m
[32m+[m[41m    [m
[32m+[m[32m    raw = chat(prompt, system=system, temperature=temperature)[m
[32m+[m[41m    [m
[32m+[m[32m    # Clean up any ```json fences[m
[32m+[m[32m    raw = raw.strip()[m
[32m+[m[32m    if raw.startswith("```"):[m
[32m+[m[32m        raw = raw.strip("`")[m
[32m+[m[32m        if raw.lower().startswith("json"):[m
[32m+[m[32m            raw = raw[4:][m
[32m+[m[32m        raw = raw.strip()[m
[32m+[m[41m    [m
[32m+[m[32m    # Parse JSON[m
[32m+[m[32m    return json.loads(raw)[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### How Agents Use the LLM Client[m
[32m+[m
[32m+[m[32m```python[m
[32m+[m[32m# Example: How the Classifier agent uses it[m
[32m+[m
[32m+[m[32mdef classify(complaint: dict) -> dict:[m
[32m+[m[32m    """Classify a complaint using LLM"""[m
[32m+[m[41m    [m
[32m+[m[32m    prompt = f"""Classify the complaint below.[m
[32m+[m[41m    [m
[32m+[m[32mCategory: UPI, ATM, Card, Loan, NetBanking, General[m
[32m+[m[32mSeverity: Critical, High, Medium, Low[m
[32m+[m[32mSentiment: Angry, Frustrated, Neutral, Polite[m
[32m+[m
[32m+[m[32mReturn JSON: {{"category": "...", "severity": "...", "sentiment": "...", "rationale": "..."}}[m
[32m+[m
[32m+[m[32mComplaint: {complaint['complaint_text']}[m
[32m+[m[32mAmount: {complaint.get('amount_involved')}[m
[32m+[m[32m"""[m
[32m+[m[41m    [m
[32m+[m[32m    # Call Groq through the client[m
[32m+[m[32m    result = chat_json(prompt, system="You are a complaint classifier.")[m
[32m+[m[41m    [m
[32m+[m[32m    return result[m
[32m+[m[32m```[m
[32m+[m
