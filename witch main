[32m+[m[32m│                                                                      │[m
[32m+[m[32m└──────────────────────────────────────────────────────────────────────┘[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Layer 4: Risk Scoring[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32m┌──────────────────────────────────────────────────────────────────────┐[m
[32m+[m[32m│                    RISK SCORE CALCULATION                           │[m
[32m+[m[32m├──────────────────────────────────────────────────────────────────────┤[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  THREE SUB-SCORES:                                                  │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  1. OMBUDSMAN ESCALATION RISK (45% weight)                         │[m
[32m+[m[32m│     ────────────────────────────────                                │[m
[32m+[m[32m│     Factors:                                                        │[m
[32m+[m[32m│     • breach_probability × 40  (0-40 points)                        │[m
[32m+[m[32m│     • severity: Critical(+30), High(+20), Medium(+10), Low(+3)     │[m
[32m+[m[32m│     • complaint_count × 3      (0-15 points)                        │[m
[32m+[m[32m│     • amount ≥ 100000 (+12), ≥25000 (+6)                           │[m
[32m+[m[32m│     • angry_history × 2       (0-8 points)                         │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│     Example:                                                        │[m
[32m+[m[32m│     - breach_prob = 0.6 → 0.6 × 40 = 24                            │[m
[32m+[m[32m│     - severity = High → +20                                        │[m
[32m+[m[32m│     - complaints = 2 → +6                                          │[m
[32m+[m[32m│     - amount = 50000 → +6                                          │[m
[32m+[m[32m│     - angry_count = 1 → +2                                         │[m
[32m+[m[32m│     ─────────────────────────────────                              │[m
[32m+[m[32m│     OMBUDSMAN = 58/100                                              │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  2. CHURN RISK (30% weight)                                        │[m
[32m+[m[32m│     ─────────────────                                              │[m
[32m+[m[32m│     Factors:                                                        │[m
[32m+[m[32m│     • total_complaints × 6        (0-30 points)                   │[m
[32m+[m[32m│     • unresolved × 5             (0-25 points)                    │[m
[32m+[m[32m│     • categories_touched × 6      (0-20 points)                    │[m
[32m+[m[32m│     • Angry/Frustrated = +12                                        │[m
[32m+[m[32m│     • Critical/High = +8                                          │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  3. SOCIAL MEDIA RISK (25% weight)                                │[m
[32m+[m[32m│     ──────────────────────                                         │[m
[32m+[m[32m│     Factors:                                                        │[m
[32m+[m[32m│     • twitter/whatsapp_complaints × 12  (0-45 points)             │[m
[32m+[m[32m│     • current channel is public = +18                             │[m
[32m+[m[32m│     • sentiment = Angry (+22), Frustrated (+10)                   │[m
[32m+[m[32m│     • severity = Critical (+8)                                     │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  OVERALL CALCULATION:                                               │[m
[32m+[m[32m│  ────────────────────                                               │[m
[32m+[m[32m│  overall = 0.45 × ombudsman + 0.30 × churn + 0.25 × social        │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  Example:                                                           │[m
[32m+[m[32m│  overall = 0.45 × 58 + 0.30 × 52 + 0.25 × 45                      │[m
[32m+[m[32m│          = 26.1 + 15.6 + 11.25                                     │[m
[32m+[m[32m│          = 52.95 → 53/100                                          │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m└──────────────────────────────────────────────────────────────────────┘[m
[32m+[m[32m```[m
[32m+[m
[32m+[m[32m### Layer 5: Auto-Resolution Logic[m
[32m+[m
[32m+[m[32m```[m
[32m+[m[32m┌──────────────────────────────────────────────────────────────────────┐[m
[32m+[m[32m│                    AUTO-RESOLUTION LOGIC                             │[m
[32m+[m[32m├──────────────────────────────────────────────────────────────────────┤[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  WHY AUTO-RESOLVE?                                                   │[m
[32m+[m[32m│  ─────────────────                                                   │[m
[32m+[m[32m│  • 18.6% of complaints are duplicates or simple cases             │[m
[32m+[m[32m│  • Don't waste human time on these                                 │[m
[32m+[m[32m│  • Free up agents for complex issues                               │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  RULES:                                                             │[m
[32m+[m[32m│  ───────                                                            │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  Rule 1: DUPLICATE → auto_resolved_dup                              │[m
[32m+[m[32m│  ─────────────────────────────────────                              │[m
[32m+[m[32m│  IF Agent 3 finds is_duplicate = True THEN                         │[m
[32m+[m[32m│      status = "auto_resolved_dup"                                  │[m
[32m+[m[32m│      Don't generate new response (use prior complaint's response)  │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  Rule 2: SIMPLE CASE → auto_resolved_std                           │[m
[32m+[m[32m│  ─────────────────────────────────────────                          │[m
[32m+[m[32m│  IF severity IN [Low, Medium]                                       │[m
[32m+[m[32m│     AND sentiment = Polite                                          │[m
[32m+[m[32m│     AND category IN [UPI, ATM, Card, NetBanking, Loan, General]   │[m
[32m+[m[32m│  THEN                                                               │[m
[32m+[m[32m│      status = "auto_resolved_std"                                   │[m
[32m+[m[32m│      Generate standard template response                            │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  Rule 3: DEFAULT → open                                            │[m
[32m+[m[32m│  ──────────────────────                                             │[m
[32m+[m[32m│  ELSE                                                               │[m
[32m+[m[32m│      status = "open"                                                │[m
[32m+[m[32m│      Human needs to review                                          │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m│  STATISTICS:                                                        │[m
[32m+[m[32m│  ───────────                                                        │[m
[32m+[m[32m│  From 1000 complaints:                                              │[m
[32m+[m[32m│  - 86 duplicates (8.6%)                                             │[m
[32m+[m[32m│  - 100 auto-resolved_std (10%)                                      │[m
[32m+[m[32m│  - Total: 186/1000 = 18.6% auto-resolved                            │[m
[32m+[m[32m│                                                                      │[m
[32m+[m[32m└──────────────────────────────────────────────────────────────────────┘[m
[32m+[m[32m```[m
