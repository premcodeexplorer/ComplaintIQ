[32m+[m[32m# agents/root_cause.py[m
[32m+[m
[32m+[m[32mMIN_CLUSTER_SIZE = 5      # At least 5 complaints[m
[32m+[m[32mDOMINANCE_THRESHOLD = 0.60  # 60% must be same category[m
[32m+[m
[32m+[m[32mdef detect(k=12):[m
[32m+[m[32m    # Run KMeans[m
[32m+[m[32m    labels = kmeans.fit_predict(embeddings)[m
[32m+[m[41m    [m
[32m+[m[32m    for cluster_id in range(k):[m
[32m+[m[32m        cluster_indices = where(labels == cluster_id)[m
[32m+[m[32m        cluster_size = len(cluster_indices)[m
[32m+[m[41m        [m
[32m+[m[32m        if cluster_size < MIN_CLUSTER_SIZE:[m
[32m+[m[32m            continue  # Too small[m
[32m+[m[41m        [m
[32m+[m[32m        # Analyze cluster[m
[32m+[m[32m        categories = [metas[i]["category"] for i in cluster_indices][m
[32m+[m[32m        locations = [metas[i]["location"] for i in cluster_indices][m
[32m+[m[41m        [m
[32m+[m[32m        most_common_category = Counter(categories).most_common(1)[0][m
[32m+[m[32m        category_share = most_common_category[1] / cluster_size[m
[32m+[m[41m        [m
[32m+[m[32m        # If dominant category > 60% → ALERT[m
[32m+[m[32m        if category_share >= DOMINANCE_THRESHOLD:[m
[32m+[m[32m            alert = {[m
[32m+[m[32m                "cluster_id": cluster_id,[m
[32m+[m[32m                "category": most_common_category[0],[m
[32m+[m[32m                "count": cluster_size,[m
[32m+[m[32m                "category_share": category_share,[m
[32m+[m[32m                # ... location analysis[m
[32m+[m[32m            }[m
[32m+[m[32m            alerts.append(alert)[m
[32m+[m[41m    [m
[32m+[m[32m    return alerts[m
